# PostgreSQL externo. Em produção, use a connection string do provedor do banco.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Opcional, recomendado para Neon: URL sem pooler usada por migrations Prisma.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Chave longa e aleatória usada para assinar o cookie de sessão.
AUTH_SECRET="troque-por-uma-chave-grande-e-aleatoria"
